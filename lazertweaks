#!/usr/bin/env bash

# Setup XDG vars.
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export BINDIR="${BINDIR:-$HOME/.local/bin}"

# Editor for the config. file
export EDITOR="${EDITOR:-nano}"

# Default env. vars
export SDL_VIDEO_DOUBLE_BUFFER=${SDL_VIDEO_DOUBLE_BUFFER:-1}

# Audio: set BASS device period to 128 samples (see config and https://github.com/ppy/osu-framework/pull/6724 for details)
export OSU_TEMP_TESTING_BASS_CONFIG_DEV_PERIOD=-128

# Upstream source for the lazertweaks script
UPSTREAM="${UPSTREAM:-https://raw.githubusercontent.com/NelloKudo/lazer-tweaks/main/lazertweaks}"

########################################################

print()
{
    echo -e "\033[1;32mScript:\033[0m $*"
}

errorExit()
{
    echo -e "\033[1;31mError:\033[0m $*" >&2
    exit 1
}

readConfig()
{
    # source config.cfg for user overrides
    set -a
    # shellcheck source=/dev/null
    source "$XDG_DATA_HOME/lazertweaks/config.cfg" 2>/dev/null
    set +a
}

wmTweaks()
{
    # add WM_NAME manually to be detected by Discord
    # shellcheck disable=SC2016
    nohup setsid setsid /bin/sh -c \
        'sleep 3; wid="$(xdotool search --all --class osu\!)"; [ -n "$wid" ] && xprop -id "$wid" -f WM_NAME 8s -set WM_NAME "osu\!"' \
        >/dev/null 2>&1 &
}

removeScript()
{
    read -p "Are you sure you want to remove $XDG_DATA_HOME/lazertweaks? (y/N): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$XDG_DATA_HOME/lazertweaks"
        print "Removed $XDG_DATA_HOME/lazertweaks."

        rm "$BINDIR/lazertweaks"
        print "Removed $BINDIR/lazertweaks."
    else
        print "Cancelled."
    fi
}

updateScript()
{
    if ! command -v curl &> /dev/null; then
        errorExit "curl is needed to update the script, please install it with your package manager."
    fi

    local target="$BINDIR/lazertweaks"
    local backup="$XDG_DATA_HOME/lazertweaks/lazertweaks.bak"
    local tmp

    print "Fetching latest lazertweaks from upstream.."
    tmp="$(mktemp)" || errorExit "Failed to create a temporary file."

    if ! curl -fsSL -o "$tmp" "$UPSTREAM"; then
        rm -f "$tmp"
        errorExit "Failed to download the latest lazertweaks from upstream."
    fi

    # make sure we got a non-empty shell script
    if [ ! -s "$tmp" ] || ! head -n 1 "$tmp" | grep -q '^#!'; then
        rm -f "$tmp"
        errorExit "Downloaded file doesn't look like a valid script, aborting."
    fi

    # skip the update if nothing changed
    if [ -f "$target" ] && cmp -s "$tmp" "$target"; then
        rm -f "$tmp"
        print "Already up to date."
        return
    fi

    if [ -f "$target" ]; then
        cp "$target" "$backup" || errorExit "Failed to back up the current script."
        print "Backed up current script to $backup"
    fi

    mv "$tmp" "$target" || errorExit "Failed to replace the script."
    chmod +x "$target"
    print "Updated lazertweaks successfully."
}

launchOsu()
{
    readConfig
    wmTweaks

    print "Launching osu!lazer.."
    exec $PRE_LAUNCH_ARGS "$XDG_DATA_HOME/lazertweaks/osu.AppImage"
}

########################################################

case $1 in
    '--config')
        exec "$EDITOR" "$XDG_DATA_HOME/lazertweaks/config.cfg"
    ;;

    '--remove')
        removeScript
    ;;

    '--update')
        updateScript
    ;;

    *)
        launchOsu
    ;;
esac
